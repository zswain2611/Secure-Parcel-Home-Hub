#include <Wire.h>
#include <I2CKeyPad.h>
#include <SPI.h>
#include <MFRC522.h>
#include <LedControl.h>
#include <Stepper.h>

// --- PIN DEFINITIONS ---
#define RST_PIN         9
#define SS_RFID         10   
#define LED_CS          7    
#define LED_DIN         6    
#define LED_CLK         A1   // Analog pin used as digital for conflict-free SPI/Matrix
#define BUZZER_PIN      8
#define STEPS_PER_REV   2048 // Full rotation steps for 28BYJ-48 stepper

// --- CUSTOM BITMAPS (8x8 Icons) ---
const byte iconLocked[8] = {0x3C, 0x42, 0x81, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF}; 
const byte iconOpen[8]   = {0x18, 0x3C, 0x7E, 0xFF, 0x18, 0x18, 0x18, 0x18}; 
const byte iconError[8]  = {0x81, 0x42, 0x24, 0x18, 0x18, 0x24, 0x42, 0x81}; 

// --- OBJECT INITIALIZATION ---
I2CKeyPad keyPad(0x20); 
MFRC522 mfrc522(SS_RFID, RST_PIN);
LedControl lc = LedControl(LED_DIN, LED_CLK, LED_CS, 1); 
Stepper myStepper(STEPS_PER_REV, 2, 4, 3, 5);

// --- SYSTEM VARIABLES ---
char keymap[19] = "123A456B789C*0#D"; 
const String courierUID  = "46 59 C7 6E"; 
const String customerUID = "E7 D5 C1 01"; 
const String masterPIN   = "1234";

String inputPIN = "";
bool isLocked = true;
unsigned long lastKeyTime = 0;

// --- DISPLAY FUNCTION ---
// Renders the selected 8x8 bitmap to the MAX7219 Matrix
void drawIcon(const byte icon[]) {
  lc.clearDisplay(0);
  for (int i = 0; i < 8; i++) {
    lc.setRow(0, i, icon[i]);
  }
}

// --- CORE SYSTEM LOGIC ---

// Handles physical unlock, status icon update, and Serial logging
void unlockSequence(String user) {
  if (!isLocked) return;
  Serial.print("LOG: ACCESS_GRANTED | USER: "); Serial.println(user);
  drawIcon(iconOpen);
  tone(BUZZER_PIN, 1500, 200); 
  myStepper.step(512); // Rotates 90 degrees to unlock
  isLocked = false;
}

// Resecures the system manually or via master command
void lockSequence(String reason) {
  if (isLocked) return;
  Serial.print("LOG: SYSTEM_RESECURED | REASON: "); Serial.println(reason);
  myStepper.step(-512); // Reverse 90 degrees to lock
  drawIcon(iconLocked);
  tone(BUZZER_PIN, 800, 400);
  isLocked = true;
}

// Visual and audio feedback for unauthorized access attempts
void denySequence(String reason) {
  Serial.print("LOG: ACCESS_DENIED | REASON: "); Serial.println(reason);
  drawIcon(iconError); 
  tone(BUZZER_PIN, 150, 1000); 
  delay(2000);
  drawIcon(isLocked ? iconLocked : iconOpen);
}

// --- INPUT HANDLERS ---

// Reads RFID Tag UID and compares against authorized whitelist
void handleRFID() {
  String readUID = "";
  for (byte i = 0; i < mfrc522.uid.size; i++) {
    readUID.concat(String(mfrc522.uid.uidByte[i] < 0x10 ? " 0" : " "));
    readUID.concat(String(mfrc522.uid.uidByte[i], HEX));
  }
  readUID.toUpperCase();
  readUID = readUID.substring(1);

  Serial.print("LOG: RFID_SCAN | UID: "); Serial.println(readUID);

  if (readUID == courierUID || readUID == customerUID) {
    unlockSequence(readUID == courierUID ? "COURIER" : "CUSTOMER");
  } else {
    denySequence("UNAUTHORIZED_TAG");
  }
  mfrc522.PICC_HaltA(); // Stop reading to prevent duplicate scans
}

// Manages PIN entry logic and function keys (D = Lock, # = Enter, * = Clear)
void handleKeypress(char key) {
  if (key == 'D') {
    if (!isLocked) lockSequence("MANUAL_CMD");
    return;
  }
  if (key == '#') {
    if (inputPIN == masterPIN) unlockSequence("PIN_ENTRY");
    else denySequence("WRONG_PIN");
    inputPIN = "";
  } 
  else if (key == '*') {
    inputPIN = "";
    tone(BUZZER_PIN, 800, 100);
  } 
  else if (isdigit(key)) {
    inputPIN += key;
    tone(BUZZER_PIN, 2000, 50);
  }
}

// --- SETUP & LOOP ---

void setup() {
  Serial.begin(9600); // Communication for Processing Dashboard
  Wire.begin();       // I2C for Keypad
  keyPad.begin();

  // Initialize Matrix display
  lc.shutdown(0, false);
  lc.setIntensity(0, 1); // Dimmed to prevent glare in demo video
  lc.clearDisplay(0);
  
  // Initialize RFID Reader
  SPI.begin();
  mfrc522.PCD_Init();
  
  pinMode(BUZZER_PIN, OUTPUT);
  myStepper.setSpeed(12);
  
  drawIcon(iconLocked);
  Serial.println("LOG: SECURE_PARCEL_HUB_ACTIVE | STATUS: SECURED");
}

void loop() {
  // Check for new RFID tags
  if (mfrc522.PICC_IsNewCardPresent() && mfrc522.PICC_ReadCardSerial()) {
    handleRFID();
  }

  // Check for I2C Keypad input with debounce timing
  if (keyPad.isPressed()) {
    uint8_t index = keyPad.getKey();
    if (index < 16 && (millis() - lastKeyTime > 350)) {
      handleKeypress(keymap[index]);
      lastKeyTime = millis();
    }
  }
}
